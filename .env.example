# InstantDB Configuration
# Get your App ID and Admin Token from https://instantdb.com/dash
NEXT_PUBLIC_INSTANT_APP_ID=your_instantdb_app_id_here
INSTANT_APP_ADMIN_TOKEN=your_admin_token_here

# Admin Configuration (optional - defaults to empty if not set)
# Set this to change the admin email without modifying code
ADMIN_EMAIL=your_admin_email@example.com
